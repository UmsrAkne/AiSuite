<UserControl
    x:Class="AiSuite.Views.Tools.RectMeasure"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:AiSuite.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tools="clr-namespace:AiSuite.ViewModels.Tools"
    d:DataContext="{d:DesignInstance tools:RectMeasureViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding
            Key="C"
            Command="{Binding CopyCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="Esc" Command="{Binding ResetSelectionCommand}" />
    </UserControl.InputBindings>
    <Grid Background="{StaticResource DarkBackgroundBrush}">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            </Style>

            <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            </Style>
        </Grid.Resources>
        <b:Interaction.Behaviors>
            <behaviors:ImageDropBehavior ImagePath="{Binding ImagePath}" />
        </b:Interaction.Behaviors>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,10,0"
                Command="{Binding ReloadCommand}"
                Content="Reload" />
            <TextBlock
                Margin="6,0"
                Padding="0,1,0,0"
                VerticalAlignment="Center"
                Text="表示倍率:" />
            <ComboBox
                Width="80"
                ItemsSource="{Binding AvailableScales}"
                SelectedItem="{Binding Scale}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource CommonFontSize}"
                            Foreground="{StaticResource CommonForegroundBrush}"
                            Text="{Binding StringFormat={}{0:P0}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Separator Width="20" Background="Transparent" />

            <StackPanel Orientation="Horizontal">

                <StackPanel.Resources>
                    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                        <Setter Property="Margin" Value="4,0,20,0" />
                        <Setter Property="Width" Value="60" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="TextAlignment" Value="Center" />
                    </Style>
                </StackPanel.Resources>

                <TextBlock VerticalAlignment="Center" Text="X:" />
                <TextBox Text="{Binding ScreenX, StringFormat={}{0:F0}, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock VerticalAlignment="Center" Text="Y:" />
                <TextBox Text="{Binding ScreenY, StringFormat={}{0:F0}, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock VerticalAlignment="Center" Text="W:" />
                <TextBox Text="{Binding ScreenWidth, StringFormat={}{0:F0}, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock VerticalAlignment="Center" Text="H:" />
                <TextBox Text="{Binding ScreenHeight, StringFormat={}{0:F0}, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer
            Grid.Row="1"
            Grid.Column="0"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Image
                    x:Name="TargetImage"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Source="{Binding ImagePath}"
                    Stretch="None">
                    <Image.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                    </Image.LayoutTransform>
                </Image>

                <!-- 視覚化レイヤー -->
                <Path Fill="#88000000" IsHitTestVisible="False">
                    <Path.Data>
                        <CombinedGeometry GeometryCombineMode="Exclude">
                            <CombinedGeometry.Geometry1>
                                <!-- Canvasと同じサイズの全体矩形 -->
                                <RectangleGeometry Rect="0,0,10000,10000" />
                            </CombinedGeometry.Geometry1>

                            <CombinedGeometry.Geometry2>
                                <!-- ViewModelのRectにバインド -->
                                <RectangleGeometry Rect="{Binding SelectionArea}" />
                            </CombinedGeometry.Geometry2>

                        </CombinedGeometry>
                    </Path.Data>
                    <Path.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                    </Path.LayoutTransform>
                </Path>

                <!-- 操作レイヤー -->
                <Canvas Background="Transparent">
                    <Canvas.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                    </Canvas.LayoutTransform>
                    <b:Interaction.Behaviors>
                        <behaviors:MouseSelectionBehavior
                            ConfirmSelectionCommand="{Binding ConfirmSelectionCommand}"
                            ImageHeight="{Binding PixelHeight}"
                            ImageWidth="{Binding PixelWidth}"
                            Scale="{Binding Scale}"
                            SelectionRect="{Binding SelectionArea, Mode=TwoWay}" />
                    </b:Interaction.Behaviors>
                </Canvas>
            </Grid>
        </ScrollViewer>

        <GroupBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="5"
            FontSize="{StaticResource CommonFontSize}"
            Header="History">
            <ListBox ItemsSource="{Binding History}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock FontSize="{StaticResource CommonFontSize}" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                            <TextBlock
                                FontSize="{StaticResource CommonFontSize}"
                                FontWeight="Bold"
                                Text="{Binding Description}" />
                            <TextBlock FontSize="{StaticResource CommonFontSize}" Text="{Binding Detail}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <StatusBar
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="6,2"
            Background="{StaticResource MiddleBackgroundBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding ImagePath}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding PixelWidth}" />
                    <TextBlock Text="*" />
                    <TextBlock Text="{Binding PixelHeight}" />
                    <TextBlock Text=" px" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>



</UserControl>