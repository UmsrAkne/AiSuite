<UserControl
    x:Class="AiSuite.Views.Tools.ModelBrowser"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AiSuite.Views.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <TextBlock Text="Model Browser" />
    </Grid>
</UserControl>