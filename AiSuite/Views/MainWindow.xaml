<Window
    x:Class="AiSuite.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:AiSuite.ViewModels"
    Title="{Binding Title}"
    Width="525"
    Height="350"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource MiddleBackgroundBrush}"
            BorderBrush="DarkGray"
            BorderThickness="0,0,1,0">
            <ListBox BorderThickness="0" ItemsSource="{Binding Tools}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:IToolViewModel}">
                        <TextBlock
                            Padding="10,5"
                            FontSize="{StaticResource CommonFontSize}"
                            Foreground="{StaticResource CommonForegroundBrush}"
                            Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="ContentRegion" />
    </Grid>
</Window>